---
// Landing page — standalone Astro page, no Starlight layout
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="A-Society is a reusable, portable agentic harness for project work: structured memory, role-based workflows, runtime orchestration, verification, and self-improvement." />
  <meta property="og:title" content="A-Society — An agentic harness for project work" />
  <meta property="og:description" content="A well-harnessed project makes a good agent reliable. A poorly harnessed project makes a great agent guess." />
  <meta property="og:type" content="website" />
  <title>A-Society — An agentic harness for project work</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    /* ─── Design tokens ─────────────────────────────────── */
    :root {
      --bg:       #07080a;
      --bg-1:     #0d1018;
      --bg-2:     #12161f;
      --card-bg:  rgba(255,255,255,0.025);
      --card-hover: rgba(255,255,255,0.045);
      --accent:   #5EEAD4;
      --accent-2: #2DD4BF;
      --accent-3: #818cf8;
      --accent-dim:  rgba(94,234,212,0.10);
      --accent-glow: rgba(94,234,212,0.20);
      --text:     #f1f5f9;
      --text-2:   #94a3b8;
      --text-3:   #4b5563;
      --border:   rgba(255,255,255,0.07);
      --border-1: rgba(255,255,255,0.13);
      --radius:   12px;
      --radius-sm: 8px;
      --font: 'Inter', system-ui, -apple-system, sans-serif;
      --mono: 'JetBrains Mono', 'Fira Code', monospace;
      --max-w: 1120px;
    }

    /* ─── Reset ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    img, svg { display: block; }
    ul { list-style: none; }

    /* ─── Scroll animations ──────────────────────────────── */
    [data-a] {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s cubic-bezier(0.4,0,0.2,1),
                  transform 0.7s cubic-bezier(0.4,0,0.2,1);
    }
    [data-a].visible { opacity: 1; transform: translateY(0); }
    [data-a][data-d="1"] { transition-delay: 0.08s; }
    [data-a][data-d="2"] { transition-delay: 0.16s; }
    [data-a][data-d="3"] { transition-delay: 0.24s; }
    [data-a][data-d="4"] { transition-delay: 0.32s; }

    /* ─── Layout helpers ────────────────────────────────── */
    .container {
      max-width: var(--max-w);
      margin-inline: auto;
      padding-inline: 1.5rem;
    }
    section { position: relative; }

    /* ─── NAV ───────────────────────────────────────────── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 0.875rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      background: rgba(7, 8, 10, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      transition: border-color 0.3s;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: -0.01em;
    }
    .nav-logo-mark {
      width: 28px;
      height: 28px;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .nav-links a {
      padding: 0.375rem 0.75rem;
      font-size: 0.875rem;
      color: var(--text-2);
      border-radius: 6px;
      transition: color 0.2s, background 0.2s;
    }
    .nav-links a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
    .nav-cta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1.125rem;
      border-radius: var(--radius-sm);
      font-size: 0.875rem;
      font-weight: 500;
      transition: all 0.2s;
      cursor: pointer;
      border: none;
    }
    .btn-primary {
      background: var(--accent);
      color: #07080a;
    }
    .btn-primary:hover { background: #7ff0db; transform: translateY(-1px); }
    .btn-ghost {
      background: transparent;
      color: var(--text-2);
      border: 1px solid var(--border-1);
    }
    .btn-ghost:hover { color: var(--text); border-color: rgba(255,255,255,0.25); background: rgba(255,255,255,0.04); }
    .nav-mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--text);
      cursor: pointer;
      padding: 0.25rem;
    }

    /* ─── HERO ──────────────────────────────────────────── */
    .hero {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 6rem 1.5rem 4rem;
      text-align: center;
      overflow: hidden;
    }
    .hero-orb {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      filter: blur(80px);
    }
    .hero-orb-1 {
      width: 700px;
      height: 700px;
      background: radial-gradient(circle, rgba(94,234,212,0.14) 0%, transparent 70%);
      top: -200px;
      right: -150px;
    }
    .hero-orb-2 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(129,140,248,0.10) 0%, transparent 70%);
      bottom: 0;
      left: -100px;
    }
    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 64px 64px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 0%, transparent 80%);
    }
    .hero-inner {
      position: relative;
      z-index: 1;
      max-width: 820px;
      margin-inline: auto;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--accent-dim);
      border: 1px solid rgba(94,234,212,0.2);
      border-radius: 100px;
      padding: 0.3rem 0.875rem;
      font-size: 0.8125rem;
      color: var(--accent);
      font-weight: 500;
      margin-bottom: 2rem;
      letter-spacing: 0.01em;
    }
    .hero-badge-dot {
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
      animation: pulse 2.5s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.7); }
    }
    .hero-heading {
      font-size: clamp(2.75rem, 7vw, 5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.08;
      margin-bottom: 1.5rem;
    }
    .hero-heading .line-1 { color: var(--text); }
    .hero-heading .line-2 {
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 40%, var(--accent-3) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: clamp(1rem, 2.5vw, 1.25rem);
      color: var(--text-2);
      max-width: 560px;
      margin-inline: auto;
      margin-bottom: 2.5rem;
      line-height: 1.65;
      font-weight: 400;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.875rem;
      flex-wrap: wrap;
    }
    .btn-hero-primary {
      padding: 0.75rem 1.75rem;
      font-size: 1rem;
      background: var(--accent);
      color: #07080a;
      border-radius: var(--radius-sm);
      font-weight: 600;
      box-shadow: 0 0 32px var(--accent-glow);
      transition: all 0.2s;
    }
    .btn-hero-primary:hover {
      background: #7ff0db;
      box-shadow: 0 0 48px rgba(94,234,212,0.35);
      transform: translateY(-2px);
    }
    .btn-hero-ghost {
      padding: 0.75rem 1.75rem;
      font-size: 1rem;
      background: transparent;
      border: 1px solid var(--border-1);
      color: var(--text-2);
      border-radius: var(--radius-sm);
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-hero-ghost:hover {
      color: var(--text);
      border-color: rgba(255,255,255,0.25);
      background: rgba(255,255,255,0.04);
      transform: translateY(-1px);
    }
    .hero-note {
      margin-top: 1.25rem;
      font-size: 0.8125rem;
      color: var(--text-3);
    }
    .hero-note code {
      font-family: var(--mono);
      color: var(--text-2);
      background: rgba(255,255,255,0.06);
      padding: 0.15em 0.5em;
      border-radius: 4px;
      font-size: 0.8125rem;
    }

    /* ─── Section shared ────────────────────────────────── */
    .section-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .section-heading {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.15;
    }
    .section-sub {
      font-size: 1.0625rem;
      color: var(--text-2);
      margin-top: 1rem;
      max-width: 560px;
      line-height: 1.7;
    }

    /* ─── PROBLEM ───────────────────────────────────────── */
    .problem {
      padding: 5rem 0 4rem;
      border-top: 1px solid var(--border);
    }
    .problem-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .problem-text .section-sub {
      max-width: none;
    }
    .problem-list {
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }
    .problem-item {
      display: flex;
      align-items: flex-start;
      gap: 0.875rem;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 0.875rem 1.125rem;
    }
    .problem-icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      color: #f87171;
      margin-top: 1px;
    }
    .problem-item p {
      font-size: 0.9375rem;
      color: var(--text-2);
      line-height: 1.55;
    }
    .problem-item strong { color: var(--text); font-weight: 500; }

    /* ─── CORE BET ──────────────────────────────────────── */
    .core-bet {
      padding: 5rem 0;
    }
    .core-bet-inner {
      max-width: 800px;
      margin-inline: auto;
      text-align: center;
    }
    .core-bet-quote {
      position: relative;
      background: linear-gradient(135deg, rgba(94,234,212,0.06) 0%, rgba(129,140,248,0.06) 100%);
      border: 1px solid rgba(94,234,212,0.2);
      border-radius: var(--radius);
      padding: 2.5rem 3rem;
      margin: 2rem 0;
    }
    .core-bet-quote::before {
      content: '\201C';
      position: absolute;
      top: -0.5rem;
      left: 2rem;
      font-size: 6rem;
      line-height: 1;
      color: var(--accent);
      opacity: 0.25;
      font-family: Georgia, serif;
    }
    .core-bet-quote p {
      font-size: clamp(1.125rem, 2.5vw, 1.375rem);
      font-weight: 500;
      line-height: 1.6;
      letter-spacing: -0.01em;
      color: var(--text);
      position: relative;
      z-index: 1;
    }
    .core-bet-tagline {
      font-size: 1.0625rem;
      color: var(--text-2);
      line-height: 1.7;
    }
    .core-bet-tagline strong { color: var(--accent); font-weight: 500; }

    /* ─── FEATURES ──────────────────────────────────────── */
    .features {
      padding: 5rem 0;
      border-top: 1px solid var(--border);
    }
    .features-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .feature-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem 1.75rem 2rem;
      transition: border-color 0.25s, background 0.25s, transform 0.25s;
    }
    .feature-card:hover {
      background: var(--card-hover);
      border-color: var(--border-1);
      transform: translateY(-3px);
    }
    .feature-icon {
      width: 44px;
      height: 44px;
      background: var(--accent-dim);
      border: 1px solid rgba(94,234,212,0.15);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
      font-size: 1.375rem;
    }
    .feature-title {
      font-size: 1.0625rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 0.625rem;
    }
    .feature-desc {
      font-size: 0.9375rem;
      color: var(--text-2);
      line-height: 1.65;
    }
    .feature-tag {
      display: inline-block;
      margin-top: 1rem;
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--accent);
      background: var(--accent-dim);
      padding: 0.2em 0.6em;
      border-radius: 4px;
    }

    /* ─── HOW IT WORKS ──────────────────────────────────── */
    .how-it-works {
      padding: 5rem 0;
      border-top: 1px solid var(--border);
    }
    .how-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
      margin-top: 3rem;
    }
    .how-tree {
      background: var(--bg-1);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .how-tree-header {
      background: var(--bg-2);
      border-bottom: 1px solid var(--border);
      padding: 0.625rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .tree-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .tree-dot-1 { background: #ff5f57; }
    .tree-dot-2 { background: #febc2e; }
    .tree-dot-3 { background: #28c840; }
    .how-tree pre {
      font-family: var(--mono);
      font-size: 0.875rem;
      line-height: 1.85;
      padding: 1.5rem 1.75rem;
      color: var(--text-2);
      overflow-x: auto;
    }
    .how-tree .hl { color: var(--accent); }
    .how-tree .dim { color: var(--text-3); }
    .how-tree .note { color: #64748b; font-style: italic; }
    .how-steps {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding-top: 0.5rem;
    }
    .how-step {
      display: flex;
      gap: 1.125rem;
    }
    .how-step-num {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--accent-dim);
      border: 1px solid rgba(94,234,212,0.2);
      color: var(--accent);
      font-size: 0.75rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 0.125rem;
    }
    .how-step-content h4 {
      font-size: 0.9375rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 0.3rem;
    }
    .how-step-content p {
      font-size: 0.9rem;
      color: var(--text-2);
      line-height: 1.6;
    }
    .how-step-content code {
      font-family: var(--mono);
      font-size: 0.8125rem;
      color: var(--accent);
      background: var(--accent-dim);
      padding: 0.1em 0.4em;
      border-radius: 3px;
    }

    /* ─── WHAT'S INSIDE ─────────────────────────────────── */
    .whats-inside {
      padding: 5rem 0;
      border-top: 1px solid var(--border);
    }
    .inside-header {
      margin-bottom: 3rem;
    }
    .inside-table {
      width: 100%;
      border-collapse: collapse;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .inside-table thead {
      background: var(--bg-2);
    }
    .inside-table th {
      padding: 0.75rem 1.25rem;
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-3);
      border-bottom: 1px solid var(--border);
    }
    .inside-table td {
      padding: 0.875rem 1.25rem;
      font-size: 0.9375rem;
      vertical-align: top;
      border-bottom: 1px solid var(--border);
    }
    .inside-table tbody tr:last-child td { border-bottom: none; }
    .inside-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .inside-table .path {
      font-family: var(--mono);
      font-size: 0.875rem;
      color: var(--accent);
      white-space: nowrap;
    }
    .inside-table .desc { color: var(--text-2); line-height: 1.55; }
    .inside-table .owner {
      font-size: 0.8125rem;
      color: var(--text-3);
      white-space: nowrap;
    }

    /* ─── QUICK START ───────────────────────────────────── */
    .quickstart {
      padding: 5rem 0;
      border-top: 1px solid var(--border);
    }
    .quickstart-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }
    .quickstart-header .section-sub {
      margin-inline: auto;
    }
    .qs-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2.5rem;
      justify-content: center;
    }
    .qs-tab {
      padding: 0.5rem 1.125rem;
      border-radius: 6px;
      font-size: 0.875rem;
      font-weight: 500;
      background: transparent;
      border: 1px solid var(--border-1);
      color: var(--text-2);
      cursor: pointer;
      transition: all 0.2s;
    }
    .qs-tab.active, .qs-tab:hover {
      background: var(--accent-dim);
      border-color: rgba(94,234,212,0.25);
      color: var(--accent);
    }
    .qs-steps {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-bottom: 2rem;
    }
    .qs-step {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .qs-step-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.875rem 1.25rem;
      border-bottom: 1px solid var(--border);
      background: var(--bg-1);
    }
    .qs-step-num {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--accent);
      color: #07080a;
      font-size: 0.6875rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .qs-step-title {
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    .qs-step pre {
      font-family: var(--mono);
      font-size: 0.8125rem;
      line-height: 1.8;
      padding: 1rem 1.25rem;
      color: var(--text-2);
      overflow-x: auto;
    }
    .qs-step .cmd { color: #e2e8f0; }
    .qs-step .comment { color: #475569; }
    .qs-step .url { color: var(--accent); }
    .qs-step-note {
      padding: 0.875rem 1.25rem;
      font-size: 0.875rem;
      color: var(--text-2);
      line-height: 1.55;
      border-top: 1px solid var(--border);
    }
    .qs-step-note code {
      font-family: var(--mono);
      font-size: 0.8125rem;
      color: var(--accent);
      background: var(--accent-dim);
      padding: 0.1em 0.4em;
      border-radius: 3px;
    }
    .qs-step-note a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
    .qs-or {
      text-align: center;
      color: var(--text-3);
      font-size: 0.875rem;
      margin: 1.5rem 0;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .qs-or::before, .qs-or::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .qs-script {
      background: var(--bg-1);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      text-align: center;
    }
    .qs-script p {
      color: var(--text-2);
      font-size: 0.9375rem;
      margin-bottom: 1rem;
    }
    .qs-script pre {
      display: inline-block;
      font-family: var(--mono);
      font-size: 0.9375rem;
      background: var(--bg-2);
      border: 1px solid var(--border-1);
      border-radius: var(--radius-sm);
      padding: 0.875rem 1.5rem;
      color: var(--accent);
    }
    .qs-cta {
