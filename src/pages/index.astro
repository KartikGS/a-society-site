      <div class="features-grid">
        <div class="feature-card" data-a data-d="1">
          <div class="feature-icon">🗂</div>
          <h3 class="feature-title">Structured Memory</h3>
          <p class="feature-desc">
            <code style="font-family:var(--mono);font-size:0.8125rem;color:var(--accent);background:var(--accent-dim);padding:0.1em 0.4em;border-radius:3px">a-docs/</code>
            preserves roles, rules, indexes, and standing project truth across sessions.
            Orientation takes minutes, not conversations.
          </p>
          <span class="feature-tag">a-docs/</span>
        </div>
        <div class="feature-card" data-a data-d="2">
          <div class="feature-icon">⚡</div>
          <h3 class="feature-title">Workflow Execution</h3>
          <p class="feature-desc">
            The runtime routes work through explicit roles, enforces handoffs, preserves
            sequenced flow records, and runs closure checks. Completeness is structural,
            not self-assessed.
          </p>
          <span class="feature-tag">runtime/</span>
        </div>
        <div class="feature-card" data-a data-d="3">
          <div class="feature-icon">🔄</div>
          <h3 class="feature-title">Cross-Project Learning</h3>
          <p class="feature-desc">
            Backward-pass findings and optional upstream feedback improve universal templates,
            project-type standards, and initialization defaults — so future projects benefit
            from work done today.
          </p>
          <span class="feature-tag">general/</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────── -->
  <section class="how-it-works" id="how">
    <div class="container">
      <div data-a>
        <span class="section-label">How It Works</span>
        <h2 class="section-heading">Sits beside your project, not inside it</h2>
      </div>
